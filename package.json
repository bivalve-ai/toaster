{
  "name": "toaster-cli",
  "version": "0.0.2",
  "description": "Local-first universal session store for AI agents, powered by TOAST.",
  "type": "module",
  "bin": {
    "toaster": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "STANDARD.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "SUPPORT.md",
    "AGENTS.md",
    "docs",
    "spec"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist dist-tests",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsc -p tsconfig.test.json && node --test dist-tests/tests/*.test.js",
    "check": "npm run build && npm test && npm pack --dry-run",
    "prepack": "npm run clean && npm run build",
    "toaster": "tsc && node dist/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bivalve-ai/toaster.git"
  },
  "bugs": {
    "url": "https://github.com/bivalve-ai/toaster/issues"
  },
  "homepage": "https://github.com/bivalve-ai/toaster#readme",
  "keywords": [
    "agent",
    "session",
    "pi",
    "claude-code",
    "codex",
    "opencode",
    "toast",
    "trace",
    "library",
    "local-first"
  ],
  "author": "Bivalve AI",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
